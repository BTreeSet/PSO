{
    "api_base_url": "https://api.protonvpn.ch",
    "state_dir": "/var/lib/pso",
    "auth": {
        "username": "alice@example.com",
        "password_file": "/run/secrets/proton_password",
        "totp": "BASE32TOTPSECRET",
        "no_prompt": true
    },
    "topology": {
        "fallback_topology": "proton-logicals.example.json",
        "require_live": false
    },
    "render": {
        "template": "config.template.json",
        "topology": "proton-logicals.json",
        "output": "rendered.config.json.tmp",
        "singbox_bin": "sing-box",
        "dry_run": true,
        "sessions": [
            {
                "username": "alice@example.com",
                "tier": "Plus"
            }
        ]
    },
    "control_plane": {
        "active_config": "/etc/sing-box/config.json",
        "singbox_bin": "/usr/local/bin/sing-box",
        "outbound_tag": "proton-wg",
        "endpoint": "203.0.113.10:443",
        "peer_public_key": "replace-with-peer-public-key"
    },
    "run": {
        "proxy_url": "socks5h://127.0.0.1:1081",
        "interval_secs": 300
    }
}